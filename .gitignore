# =============================================================================
# PaperSage — Root .gitignore
# Monorepo covering papersage_backend (Java/Spring Boot) and
# papersage_frontend (React/Vite)
# =============================================================================

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------

### IntelliJ IDEA ###
.idea/
*.iws
*.iml
*.ipr

### Spring Tool Suite ###
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

### NetBeans ###
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

### VS Code ###
.vscode/
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# Java / Maven (backend)
# -----------------------------------------------------------------------------
target/
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Maven Wrapper JAR (downloaded at build time)
.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------------------------------------
# Secrets & environment variables
# -----------------------------------------------------------------------------
secrets.properties
**/secrets.properties
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Node / Frontend (React + Vite)
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
